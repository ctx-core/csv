{
	"name": "@ctx-core/csv",
	"version": "19.0.196",
	"description": "ctx-core csv",
	"keywords": [
		"ctx-core",
		"csv"
	],
	"homepage": "https://github.com/ctx-core/csv#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/csv/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/csv.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-csv@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"_types",
		"csv__data_row",
		"csv__header_row",
		"csv__parse",
		"csv__row",
		"csv__table",
		"csv__transform_stream",
		"csv_val__hydrate",
		"header_csv__toLowerCase",
		"is_readable_stream_OR_reader",
		"reader__csv__table",
		"row__csv",
		"row_a__csv",
		"table__csv"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "pnpm clean && pnpm build && pnpm test",
		"test": "pnpm run /^test:/",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 pnpm test:unit"
	},
	"dependencies": {
		"@ctx-core/table": "*",
		"ctx-core": "*"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}